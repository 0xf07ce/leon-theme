{
  "name": "Leon Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#f7f3e9",
    "editor.foreground": "#2e2e2e",
    "editorCursor.foreground": "#1a1a1a",
    "editor.selectionBackground": "#c4d0dc",
    "editor.selectionForeground": "#1a1a1a",
    "editor.inactiveSelectionBackground": "#c4d0dc80",
    "editor.lineHighlightBackground": "#00000008",
    "editorLineNumber.foreground": "#9a9a9a",
    "editorLineNumber.activeForeground": "#1a1a1a",
    "editorIndentGuide.background1": "#c8c8c8",
    "editorIndentGuide.activeBackground1": "#9a9a9a",
    "editorGutter.background": "#f2eede",
    "editorRuler.foreground": "#d2d2d2",
    "editorWhitespace.foreground": "#c4c4c4",
    "editor.foldBackground": "#cfcf9e40",

    "editorError.foreground": "#ff0000",
    "editorWarning.foreground": "#be9117",
    "editorInfo.foreground": "#aaaaaa",

    "terminal.background": "#f7f3e9",
    "terminal.foreground": "#2e2e2e",

    "activityBar.background": "#cfcfcf",
    "activityBar.foreground": "#1a1a1a",
    "sideBar.background": "#e2e2e2",
    "sideBar.foreground": "#2e2e2e",
    "statusBar.background": "#cfcfcf",
    "statusBar.foreground": "#1a1a1a",
    "titleBar.activeBackground": "#cfcfcf",
    "titleBar.activeForeground": "#1a1a1a",
    "tab.activeBackground": "#f7f3e9",
    "tab.inactiveBackground": "#d7d7d7",
    "editorGroupHeader.tabsBackground": "#d7d7d7"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#a0a0a0"
      }
    },
    {
      "scope": ["comment.block.documentation", "comment.documentation"],
      "settings": {
        "foreground": "#9fb2ac",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator.new"],
      "settings": {
        "foreground": "#009610"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "scope": ["constant.character.escape", "constant.regexp"],
      "settings": {
        "foreground": "#000000"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e06600"
      }
    },
    {
      "scope": ["constant.language", "constant.other", "variable.other.constant", "support.constant"],
      "settings": {
        "foreground": "#8000c2"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": {
        "foreground": "#e0218a"
      }
    },
    {
      "scope": ["support.function.builtin"],
      "settings": {
        "foreground": "#e0218a"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "entity.name.type.parameter", "entity.name.type.enum"],
      "settings": {
        "foreground": "#0036e0"
      }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#0a6e7a"
      }
    },
    {
      "scope": ["entity.name.namespace"],
      "settings": {
        "foreground": "#357b88"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#9d7124",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable.language.this", "variable.language.self"],
      "settings": {
        "foreground": "#9d7124"
      }
    },
    {
      "scope": ["variable.other.property.js", "variable.other.property.ts", "variable.other.object.property.js", "variable.other.object.property.ts", "meta.object-literal.key"],
      "settings": {
        "foreground": "#9d7124"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#009610"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#7b3005"
      }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.definition.decorator"],
      "settings": {
        "foreground": "#0a6e7a",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["keyword.other.unit", "support.type.property-name"],
      "settings": {
        "foreground": "#8000c2"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff0000"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#9d7124"
      }
    },
    {
      "scope": ["string.unquoted.plain.out.yaml", "string.unquoted.plain.in.yaml", "string.quoted.single.yaml", "string.quoted.double.yaml", "string.unquoted.block.yaml"],
      "settings": {
        "foreground": "#000000"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#e0218a",
    "method": "#e0218a",
    "class": "#0036e0",
    "struct": "#0036e0",
    "interface": "#0a6e7a",
    "enum": "#0036e0",
    "type": "#0036e0",
    "typeParameter": "#0036e0",
    "namespace": "#357b88",
    "macro": "#8000c2",
    "parameter": { "foreground": "#9d7124", "fontStyle": "italic" },
    "property": "#9d7124",
    "property:javascript": "#9d7124",
    "property:typescript": "#9d7124",
    "property:javascriptreact": "#9d7124",
    "property:typescriptreact": "#9d7124",
    "selfParameter": "#9d7124",
    "*.static": "#8000c2",
    "keyword": "#009610",
    "string": "#000000",
    "number": "#e06600",
    "decorator": "#0a6e7a"
  }
}
