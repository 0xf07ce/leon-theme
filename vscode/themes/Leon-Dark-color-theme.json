{
  "name": "Leon Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#c0c0c0",
    "editorCursor.foreground": "#c0c0c0",
    "editor.selectionBackground": "#214283",
    "editor.inactiveSelectionBackground": "#21428380",
    "editor.lineHighlightBackground": "#101214",
    "editorLineNumber.foreground": "#606060",
    "editorLineNumber.activeForeground": "#c0c0c0",
    "editorIndentGuide.background1": "#333333",
    "editorIndentGuide.activeBackground1": "#2b2b2b",
    "editorGutter.background": "#111315",
    "editorRuler.foreground": "#333333",
    "editorWhitespace.foreground": "#2b2b2b",
    "editor.foldBackground": "#38400b40",

    "editorError.foreground": "#ff0000",
    "editorWarning.foreground": "#be9117",
    "editorInfo.foreground": "#606060",

    "terminal.background": "#000000",
    "terminal.foreground": "#c0c0c0",

    "activityBar.background": "#111315",
    "activityBar.foreground": "#c0c0c0",
    "sideBar.background": "#0c0d0e",
    "sideBar.foreground": "#c0c0c0",
    "statusBar.background": "#111315",
    "statusBar.foreground": "#c0c0c0",
    "titleBar.activeBackground": "#111315",
    "titleBar.activeForeground": "#c0c0c0",
    "tab.activeBackground": "#000000",
    "tab.inactiveBackground": "#0c0d0e",
    "editorGroupHeader.tabsBackground": "#0c0d0e"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#606060"
      }
    },
    {
      "scope": ["comment.block.documentation", "comment.documentation"],
      "settings": {
        "foreground": "#2e7363",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator.new", "keyword.operator.delete", "variable.language.this", "variable.language.self", "constant.language"],
      "settings": {
        "foreground": "#77b767"
      }
    },
    {
      "scope": ["keyword.control.directive", "entity.name.function.preprocessor"],
      "settings": {
        "foreground": "#008000"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#6897bb"
      }
    },
    {
      "scope": ["constant.character.escape", "constant.regexp"],
      "settings": {
        "foreground": "#3c9985"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#e1e100"
      }
    },
    {
      "scope": ["constant.language.enum", "variable.other.enummember"],
      "settings": {
        "foreground": "#2b91af"
      }
    },
    {
      "scope": ["constant.other", "variable.other.constant", "support.constant", "support.variable", "entity.name.constant"],
      "settings": {
        "foreground": "#9876aa"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function", "meta.function-call.generic"],
      "settings": {
        "foreground": "#cc3333"
      }
    },
    {
      "scope": ["support.function.builtin", "support.function.magic"],
      "settings": {
        "foreground": "#cc336e"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "entity.name.type.class"],
      "settings": {
        "foreground": "#0080ff"
      }
    },
    {
      "scope": ["entity.name.type.interface"],
      "settings": {
        "foreground": "#40bcff"
      }
    },
    {
      "scope": ["entity.name.type.parameter", "entity.name.type.typedef", "support.type.primitive", "storage.type.built-in"],
      "settings": {
        "foreground": "#5555ff"
      }
    },
    {
      "scope": ["entity.name.namespace"],
      "settings": {
        "foreground": "#4ec9b0"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#cc7832",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.other.readwrite", "variable.other.object.property", "variable.other.property", "variable.other.member"],
      "settings": {
        "foreground": "#cc7832"
      }
    },
    {
      "scope": ["variable.other.global", "variable.other.readwrite.global"],
      "settings": {
        "foreground": "#cda869"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#77b767"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#8a653b"
      }
    },
    {
      "scope": ["meta.decorator", "entity.name.function.decorator", "punctuation.definition.decorator", "meta.function.decorator"],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["keyword.other.debugger"],
      "settings": {
        "foreground": "#ff3333",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff0000"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#cc3333",
    "method": "#cc3333",
    "class": "#0080ff",
    "struct": "#0080ff",
    "interface": "#40bcff",
    "enum": "#2b91af",
    "enumMember": "#2b91af",
    "type": "#5555ff",
    "typeParameter": "#5555ff",
    "namespace": "#4ec9b0",
    "macro": "#9876aa",
    "parameter": { "foreground": "#cc7832", "fontStyle": "italic" },
    "variable": "#cc7832",
    "property": "#cc7832",
    "selfParameter": "#9876aa",
    "*.static": "#9876aa",
    "keyword": "#77b767",
    "string": "#6897bb",
    "number": "#e1e100",
    "decorator": "#4ec9b0"
  }
}
